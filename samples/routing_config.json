        "details": {
          "checks": [
            {
              "name": "신입×신제품",
              "match_field": {"vehicle": "is_rookie", "job": "has_new_product"},
              "match_logic": "vehicle.is_rookie=true AND job.has_new_product=true → 배정 제외"
            },
            {
              "name": "교육 미이수 SKU",
              "match_field": {"vehicle": "excluded_skus", "job": "sku_codes"},
              "match_logic": "job.sku_codes와 vehicle.excluded_skus 교집합 있으면 배정 제외"
            }
          ],
          "action_on_violation": "skip_assignment"
        }
      },
      "C8": {
        "enabled": true,
        "name": "미결 이력 회피",
        "description": "과거 설치 미숙 미결 발생 모델은 해당 기사에게 재배정 제외",
        "details": {
          "match_field": {"vehicle": "avoid_models", "job": "sku_codes"},
          "match_logic": "job.sku_codes와 vehicle.avoid_models 교집합 있으면 배정 제외",
          "history_period_days": 365,
          "action_on_violation": "skip_assignment"
        }
      }
