# ============================================================
# VROOM Wrapper v3.0 환경 변수 설정
# ============================================================
# 이 파일을 .env로 복사하여 사용하세요:
#   cp .env.example .env
# ============================================================

# --- API 서버 ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ============================================================
# VROOM 엔진 (v3.0)
# ============================================================

# 직접 호출 모드 (true: 바이너리 직접 실행, false: vroom-express HTTP)
USE_DIRECT_CALL=true
VROOM_BINARY_PATH=/usr/local/bin/vroom
VROOM_ROUTER=osrm
VROOM_THREADS=4
VROOM_EXPLORATION=5
VROOM_TIMEOUT=300

# HTTP 폴백 (USE_DIRECT_CALL=false일 때만 사용)
VROOM_URL=http://localhost:3000

# ============================================================
# OSRM 라우팅 엔진
# ============================================================

OSRM_URL=http://localhost:5000

# 대규모 매트릭스 청킹 (v3.0)
OSRM_CHUNK_SIZE=75
OSRM_MAX_WORKERS=8

# ============================================================
# 2-Pass 최적화 (v3.0 - Roouty Engine 패턴)
# ============================================================

TWO_PASS_ENABLED=false
TWO_PASS_MAX_WORKERS=4
TWO_PASS_INITIAL_THREADS=16
TWO_PASS_ROUTE_THREADS=4

# ============================================================
# 도달 불가능 필터링 (v3.0)
# ============================================================

UNREACHABLE_FILTER_ENABLED=true
UNREACHABLE_THRESHOLD=43200

# ============================================================
# Redis 캐싱 (선택)
# ============================================================
# 비활성화하려면 주석 처리

# REDIS_URL=redis://localhost:6379

# ============================================================
# 실시간 교통 매트릭스 (v2.1+)
# ============================================================

# 활성화 여부
TRAFFIC_MATRIX_ENABLED=false

# 제공자 선택: tmap, kakao, naver, osrm
TRAFFIC_PROVIDER=osrm

# --- TMap API ---
# https://openapi.sk.com 에서 발급
# TMAP_API_KEY=your_tmap_api_key_here

# --- Kakao API ---
# https://developers.kakao.com 에서 발급
# KAKAO_API_KEY=your_kakao_api_key_here

# --- Naver API ---
# https://console.ncloud.com 에서 발급
# NAVER_CLIENT_ID=your_naver_client_id
# NAVER_CLIENT_SECRET=your_naver_client_secret

# --- 매트릭스 설정 ---
MATRIX_CACHE_TTL=300
MATRIX_PARALLEL_REQUESTS=10
