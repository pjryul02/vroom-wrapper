# ============================================================
# VROOM Wrapper v2.0 환경 변수 설정
# ============================================================
# 이 파일을 .env로 복사하여 사용하세요:
#   cp .env.example .env
# ============================================================

# --- 기본 서버 ---
VROOM_URL=http://localhost:3000
OSRM_URL=http://localhost:5000

# --- Redis 캐싱 (선택) ---
# 비활성화하려면 주석 처리
# REDIS_URL=redis://localhost:6379

# --- API 서버 ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ============================================================
# 실시간 교통 매트릭스 (Phase 1.5)
# ============================================================

# 활성화 여부
TRAFFIC_MATRIX_ENABLED=false

# 제공자 선택: tmap, kakao, naver, osrm
TRAFFIC_PROVIDER=osrm

# --- TMap API ---
# https://openapi.sk.com 에서 발급
# TMAP_API_KEY=your_tmap_api_key_here

# --- Kakao API ---
# https://developers.kakao.com 에서 발급
# KAKAO_API_KEY=your_kakao_api_key_here

# --- Naver API ---
# https://console.ncloud.com 에서 발급
# NAVER_CLIENT_ID=your_naver_client_id
# NAVER_CLIENT_SECRET=your_naver_client_secret

# --- 매트릭스 설정 ---
MATRIX_CACHE_TTL=300
MATRIX_PARALLEL_REQUESTS=10
